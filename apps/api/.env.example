DATABASE_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
REDIS_URL="redis://localhost:6379"

# Auth — generate a real secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
REFRESH_TOKEN_TTL_DAYS=7

# Object storage (MinIO locally — matches docker-compose.yml)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="careeros"
S3_SECRET_KEY="careeros123"
S3_BUCKET="careeros"

# Service-to-service auth (workers/scraper -> API internal endpoints)
INTERNAL_API_TOKEN="change-me-shared-secret"

# AI (Gemini — Phase 5) — get one at https://aistudio.google.com
GEMINI_API_KEY="change-me"
# Optional — Referral Engine public GitHub discovery. Read-only PAT (no scopes)
# lifts the rate limit 60 -> 5000/hr. github.com/settings/tokens
GITHUB_TOKEN=""
# Default vendor for both workloads. Override per-workload with LLM_PROVIDER /
# EMBEDDING_PROVIDER when the two are served by different vendors (embeddings
# and generation have separate markets — see modules/ai/llm.provider.ts).
AI_PROVIDER="gemini"
# LLM_PROVIDER="gemini"          # or "vertex"
# EMBEDDING_PROVIDER="gemini"    # or "vertex"

# Vertex AI (only when a provider above is "vertex") — see docs/VERTEX_MIGRATION.md
# GOOGLE_CLOUD_PROJECT="my-project-id"
# GOOGLE_CLOUD_LOCATION="us-central1"
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
# VERTEX_TEXT_MODEL="gemini-3.5-flash"        # defaults to GEMINI_TEXT_MODEL
# VERTEX_EMBEDDING_MODEL="gemini-embedding-2" # defaults to GEMINI_EMBEDDING_MODEL
# VERTEX_EMBED_BATCH_SIZE=1
GEMINI_TEXT_MODEL="gemini-3.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-2"
EMBEDDING_DIMS=1536
# After exhausted 429 retries, fail AI calls fast for this long instead of
# hammering a dead quota (default 10 min)
# AI_QUOTA_COOLDOWN_MS=600000

# Notifications (Phase C) — create a bot via @BotFather; message it once, then
# GET https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
NOTIFY_MIN_SCORE=70
